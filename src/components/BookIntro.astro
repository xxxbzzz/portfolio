---
import type { Lang } from "../lib/i18n";
import { labels } from "../lib/i18n";
const { lang } = Astro.props as { lang: Lang };
---

<div class="book-intro" data-book-intro aria-hidden="true">
  <div class="book-page book-page--left">
    <span class="book-kicker">PORTFOLIO / 2026</span>
    <strong>CAI<br />JIAYAN</strong>
  </div>
  <div class="book-page book-page--right">
    <span>DESIGN<br />&amp; OTHER<br />WAYS OF<br />READING</span>
    <button type="button" data-skip-intro>{labels[lang].skipIntro}</button>
  </div>
</div>

<script>
  const intro = document.querySelector("[data-book-intro]");
  const skip = document.querySelector("[data-skip-intro]");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const visited = sessionStorage.getItem("portfolio-intro-seen");

  const closeIntro = () => {
    intro?.classList.add("is-open");
    sessionStorage.setItem("portfolio-intro-seen", "true");
    window.setTimeout(() => intro?.remove(), reduced ? 0 : 1150);
  };

  if (!intro || reduced || visited) {
    intro?.remove();
  } else {
    document.documentElement.classList.add("intro-active");
    window.setTimeout(closeIntro, 250);
  }

  skip?.addEventListener("click", closeIntro);
</script>
