---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../lib/i18n";
import { labels, sitePath } from "../lib/i18n";

const { project, index, lang } = Astro.props as {
  project: CollectionEntry<"projects">;
  index: number;
  lang: Lang;
};
const data = project.data;
---

<article class="project-card" style={`--accent:${data.accent}`}>
  <a href={sitePath(`/${lang}/projects/${data.slug}/`)} aria-label={`${labels[lang].readProject}: ${data.title}`}>
    <div class="project-card__heading">
      <div>
        <span class="project-card__index">{String(index + 1).padStart(2, "0")}</span>
        <h2>{data.title}</h2>
      </div>
      <span>{data.year}</span>
    </div>

    <div class="project-card__image">
      <Image
        src={data.cover}
        alt=""
        widths={[640, 960, 1440]}
        sizes="(max-width: 760px) 100vw, 880px"
        loading={index < 2 ? "eager" : "lazy"}
      />
      <span class="project-card__view">{labels[lang].readProject} →</span>
    </div>

    <div class="project-card__description">
      <p>{data.summary}</p>
      <span>{data.medium}</span>
    </div>
  </a>
</article>
